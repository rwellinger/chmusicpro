{
  "name": "chmusicproweb",
  "version": "0.3.6",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/update-version.js",
    "start": "ng serve",
    "prebuild": "node scripts/update-version.js",
    "build": "ng build",
    "prebuild:prod": "node scripts/update-version.js",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "pretest": "node scripts/update-version.js",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:check": "ng lint --quiet",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:scss:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:arch": "depcruise src --config .dependency-cruiser.js",
    "lint:all": "npm run lint && npm run lint:scss && npm run lint:arch",
    "update-version": "node scripts/update-version.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.4",
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.4",
    "@angular/compiler": "^21.1.4",
    "@angular/core": "^21.1.4",
    "@angular/forms": "^21.1.4",
    "@angular/material": "^21.1.4",
    "@angular/platform-browser": "^21.1.4",
    "@angular/platform-browser-dynamic": "^21.1.4",
    "@angular/router": "^21.1.4",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "compromise": "^14.14.4",
    "highlight.js": "^11.11.1",
    "marked": "^16.4.0",
    "ngx-cookie-service": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.4",
    "angular-eslint": "21.2.0",
    "dependency-cruiser": "^17.2.0",
    "eslint": "^9.35.0",
    "jsdom": "^28.1.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-scss": "^6.12.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
